APP_NAME=SignalCraft
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://signalcraft:signalcraft@localhost:5432/signalcraft
REDIS_URL=redis://localhost:6379/0

# Matches Engineer Front Door's current OpenAI-compatible provider contract.
# Use "azure-openai" for Azure-hosted OpenAI deployments, or "openai" for api.openai.com.
LLM_PROVIDER=azure-openai
LLM_MODEL=gpt-4o

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

ANTHROPIC_API_KEY=

PHONE_PROVIDER=console
APPROVAL_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

PERSONAL_USE_MODE=true
REQUIRE_COLLECTION_APPROVAL=false
REQUIRE_PUBLISH_APPROVAL=true
NOTIFY_WHEN_DRAFT_READY=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/youtube.readonly

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/integrations/linkedin/callback
LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social

MEDIUM_INTEGRATION_TOKEN=

YOUTUBE_API_KEY=
ENABLE_LIVE_COLLECTION=false
ENABLE_BROWSER_SCRAPING=false
